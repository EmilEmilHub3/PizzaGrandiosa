<Window x:Class="PizzaRabbitMqClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pizza RabbitMQ Client"
        Height="500"
        Width="1100">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="RabbitMQ ordreoversigt"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1"
                   Text="Når backend opretter en SalesOrder, dukker den op her via RabbitMQ."
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="2"
                  x:Name="OrdersDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Orders}"
                  CanUserAddRows="False"
                  Margin="0,5,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="OrderId" Binding="{Binding OrderId}" Width="90"/>
                <DataGridTextColumn Header="CustomerId" Binding="{Binding CustomerId}" Width="90"/>
                <DataGridTextColumn Header="Type" Binding="{Binding OrderType}" Width="110"/>
                <DataGridTextColumn Header="Dato" Binding="{Binding Date}" Width="180"/>
                <DataGridTextColumn Header="Linjer" Binding="{Binding LineCount}" Width="70"/>
                <DataGridTextColumn Header="Produkter" Binding="{Binding ProductsSummary}" Width="*"/>
                <DataGridCheckBoxColumn Header="Accepted" Binding="{Binding IsAccepted}" Width="90"/>
                <DataGridCheckBoxColumn Header="Posted" Binding="{Binding IsPosted}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>